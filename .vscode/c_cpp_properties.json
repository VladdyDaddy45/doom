{
    "configurations": [
        {
            "name": "windows-gcc-x64",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/**"
            ],
            "compilerPath": "C:/msys64/ucrt64/bin/gcc.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "compilerArgs": [
                "src/main.cpp",
                "-Iinclude",
                "-o",
                "DOOM.exe"
            ],
            //"compilerPathInCppPropertiesJson": "C:/msys64/ucrt64/bin/gcc.exe",
            "mergeConfigurations": false,
            "recursiveIncludes": {},
            "browse": {
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "windows-g++-x64",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "${default}",
            "compilerPath": "C:/msys64/ucrt64/bin/g++.exe",
            "compilerArgs": [
                "src/main.cpp",
                "-Iinclude",
                "-o",
                "DOOM.exe"
            ],
            //"compilerPathInCppPropertiesJson": "C:/msys64/ucrt64/bin/g++.exe",
            "mergeConfigurations": false,
            "recursiveIncludes": {},
            "browse": {
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}